\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Four-way branch prediction accuracy comparison across six workloads (Icarus Verilog behavioral simulation; same instruction images used for all predictors). PicoRV32 incurs a 2-cycle stall on every branch (0\% predictive accuracy by definition). Ibex\nobreakspace  {}+\nobreakspace  {}SBP and VexRiscv\nobreakspace  {}+\nobreakspace  {}BHT are behavioural models of their documented predictor mechanisms\nobreakspace  {}\cite  {ibex,vexriscv}.\relax }}{17}{table.caption.28}\protected@file@percent }
\newlabel{tab:multiworkload}{{7}{17}{Four-way branch prediction accuracy comparison across six workloads (Icarus Verilog behavioral simulation; same instruction images used for all predictors). PicoRV32 incurs a 2-cycle stall on every branch (0\% predictive accuracy by definition). Ibex~+~SBP and VexRiscv~+~BHT are behavioural models of their documented predictor mechanisms~\cite {ibex,vexriscv}.\relax }{table.caption.28}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Accuracy--power--area trade-off summary. Accuracy values are from the six-workload unified simulation in Table\nobreakspace  {}\ref  {tab:multiworkload}. Fields marked $\dagger $ are from Vivado 2022.2 post-route reports (xc7z020clg400-1, 125\,MHz, vectorless, branchstress ROM loaded) for the two custom SoC designs (CPU\,+\,ROM\,+\,data-RAM). Fields marked $\ddagger $ are from separate core-only out-of-context syntheses under the same tool/part/clock settings (CPU core only, no instruction or data memory); numbers are not directly comparable to $\dagger $ figures due to differing scope. VexRiscv Verilog was generated from SpinalHDL (GenDynamicBHT config: RV32I, IBusSimple with DYNAMIC prediction, no cache/MMU/MUL/DIV). Neural invoke ratio is from the branch-stress workload (Table\nobreakspace  {}\ref  {tab:internal}). Average steps is the mean number of perceptron weight accumulations before early-stop termination (behavioral simulation; maximum\nobreakspace  {}8).\relax }}{18}{table.caption.29}\protected@file@percent }
\newlabel{tab:tradeoff}{{8}{18}{Accuracy--power--area trade-off summary. Accuracy values are from the six-workload unified simulation in Table~\ref {tab:multiworkload}. Fields marked $\dagger $ are from Vivado 2022.2 post-route reports (xc7z020clg400-1, 125\,MHz, vectorless, branchstress ROM loaded) for the two custom SoC designs (CPU\,+\,ROM\,+\,data-RAM). Fields marked $\ddagger $ are from separate core-only out-of-context syntheses under the same tool/part/clock settings (CPU core only, no instruction or data memory); numbers are not directly comparable to $\dagger $ figures due to differing scope. VexRiscv Verilog was generated from SpinalHDL (GenDynamicBHT config: RV32I, IBusSimple with DYNAMIC prediction, no cache/MMU/MUL/DIV). Neural invoke ratio is from the branch-stress workload (Table~\ref {tab:internal}). Average steps is the mean number of perceptron weight accumulations before early-stop termination (behavioral simulation; maximum~8).\relax }{table.caption.29}{}}
